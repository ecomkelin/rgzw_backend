# ===== LLM (排课时自然语言解析) =====
# 项目走 OpenAI 兼容协议, 切换厂商只需改下面三个变量, 零代码改动.
# 默认: DeepSeek (国内可直连, 价格低, 中文强)
LLM_API_KEY=sk-1fa3b994de9c440b89d9921b6ffab800
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_MS=8000

# 备选 (国内常用):
#   Moonshot Kimi:  LLM_BASE_URL=https://api.moonshot.cn/v1                       LLM_MODEL=moonshot-v1-8k
#   智谱 GLM:       LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4            LLM_MODEL=glm-4-flash
#   通义千问(DashScope OpenAI 兼容):  LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  LLM_MODEL=qwen-plus
