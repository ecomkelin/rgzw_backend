{
  "name": "school_manage_plat",
  "version": "1.0.0",
  "description": "科技培训学校管理系统",
  "main": "src/main.js",
  "_moduleAliases": {
    "@": "src",
    "@utils": "src/utils",
    "@models": "src/models",
    "@routers": "src/routers",
    "@middlewares": "src/middlewares",
    "@modules": "src/modules",
    "@config": "src/config"
  },
  "scripts": {
    "pm2": "cross-env NODE_ENV=production pm2 start ./config/ecosystem.config.js --only rgzw_plat",
    "pm2:restart": "cross-env NODE_ENV=production pm2 restart school_manage_plat",
    "pm2:stop": "cross-env NODE_ENV=production pm2 stop school_manage_plat",
    "dev": "cross-env NODE_ENV=dev nodemon src/main.js",
    "test": "cross-env NODE_ENV=test jest --config tests/jest.config.js --detectOpenHandles --forceExit --maxWorkers=1",
    "test:watch": "jest --watch",
    "test:coverage": "jest --config tests/jest.config.js --coverage",
    "test:e2e": "cross-env NODE_ENV=test jest --config tests/jest.e2e.config.js --detectOpenHandles --forceExit",
    "test:all": "npm run test && npm run test:e2e",
    "db:seeds": "node scripts/db/index.js",
    "db:seeds:test": "cross-env NODE_ENV=test node scripts/db/index.js",
    "test:load": "node scripts/tests/load-test.js",
    "test:load:quick": "autocannon -c 100 -d 20 http://localhost:8000/api/health",
    "postinstall": "node ./scripts/tests/download-mongodb.js"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "axios": "^1.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.3.4",
    "mongoose": "^8.1.0",
    "morgan": "^1.10.0",
    "response-time": "^2.3.2"
  },
  "devDependencies": {
    "autocannon": "^7.12.0",
    "axios-cookiejar-support": "^7.0.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.3",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3",
    "tough-cookie": "^6.0.1"
  }
}